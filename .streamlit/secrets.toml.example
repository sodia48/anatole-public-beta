# Copie ce fichier sous .streamlit/secrets.toml uniquement en local.
# Sur Streamlit Community Cloud ou Render, utilise l'interface de secrets.

ANATOLE_PUBLIC_BETA = "true"

# Valeurs possibles : login, hybrid, guest
# - login  : connexion obligatoire
# - hybrid : connexion recommandée, invité possible
# - guest  : accès invité uniquement
ANATOLE_ACCESS_MODE = "hybrid"

# Liste séparée par des virgules.
ANATOLE_ADMIN_EMAILS = "ton-adresse@example.com"

# Base PostgreSQL recommandée pour le test public.
# Sur Render, utilise plutôt la variable d'environnement DATABASE_URL.
DATABASE_URL = ""

TWELVE_DATA_API_KEY = ""

OPENAI_API_KEY = ""
OPENAI_MODEL = "gpt-5.5"

TELEGRAM_BOT_TOKEN = ""
TELEGRAM_CHAT_ID = ""

SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USERNAME = ""
SMTP_PASSWORD = ""
SMTP_USE_TLS = "true"
ALERT_EMAIL_FROM = ""
ALERT_EMAIL_TO = ""

# Décommente et configure cette section pour Google OIDC.
#
# [auth]
# redirect_uri = "https://TON-APP.streamlit.app/oauth2callback"
# cookie_secret = "UNE_LONGUE_CHAINE_ALEATOIRE"
# client_id = "CLIENT_ID_GOOGLE"
# client_secret = "CLIENT_SECRET_GOOGLE"
# server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
